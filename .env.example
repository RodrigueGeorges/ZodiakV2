# =============================================================================
# Zodiak — Variables d'environnement (exemple)
# =============================================================================
# Front (build Vite) ET back (Netlify Functions) tournent sur Netlify.
#
# EN PROD : tout se renseigne dans
#   Netlify → Site settings → Environment variables
#
# EN LOCAL : copier ce fichier en `.env` (ignoré par git) pour `netlify dev`.
#
# RÈGLE D'OR : seules les variables préfixées `VITE_` sont exposées dans le
# bundle JS public. Tout secret (OpenAI, Stripe secret, tokens Meta, VAPID
# privé...) NE DOIT JAMAIS être préfixé `VITE_`.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# CLIENT (préfixe VITE_ — publiques par design)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (clé anon = publique)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Stripe (clé publiable + price IDs — DOIVENT être identiques aux STRIPE_PRICE_* serveur)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_PRICE_PREMIUM=price_xxx          # Abo mensuel 8,90 €
VITE_STRIPE_PRICE_PREMIUM_ANNUAL=price_xxx   # Abo annuel 89 € (2 mois offerts)
VITE_STRIPE_PRICE_FILANTE=price_xxx          # Pack 10 messages
VITE_STRIPE_PRICE_LUNE=price_xxx             # Pack 30 messages
VITE_STRIPE_PRICE_CONSTELLATION=price_xxx    # Pack 100 messages
VITE_STRIPE_PRICE_GALAXIE=price_xxx          # Pack 300 messages

# Web Push (clé publique VAPID — `npx web-push generate-vapid-keys`)
VITE_VAPID_PUBLIC_KEY=

# Analytics PostHog (optionnel)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Monitoring Sentry (optionnel, DSN public par design)
VITE_SENTRY_DSN=

# URL absolue du site (liens canoniques) — optionnel
VITE_NETLIFY_URL=https://zodiakastro.com

# Deep-links canaux (affichage UI)
VITE_ZODIAK_WHATSAPP_NUMBER=33612345678      # E.164 SANS le "+"
VITE_ZODIAK_INSTAGRAM_HANDLE=zodiakastro     # handle SANS le "@"

# Admin gating côté UI (CSV)
VITE_ADMIN_EMAILS=admin@zodiakastro.com
VITE_ADMIN_USER_IDS=


# ─────────────────────────────────────────────────────────────────────────────
# SERVEUR (Netlify Functions — JAMAIS préfixées VITE_, ce sont des secrets)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...            # utilisé par push-subscribe / compute-friend-chart
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...    # SECRET — bypass RLS, ne jamais exposer

# OpenAI (chat + guidance)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# Stripe (côté serveur)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PREMIUM=price_xxx             # = VITE_STRIPE_PRICE_PREMIUM
STRIPE_PRICE_PREMIUM_ANNUAL=price_xxx      # = VITE_STRIPE_PRICE_PREMIUM_ANNUAL
STRIPE_PRICE_FILANTE=price_xxx             # = VITE_STRIPE_PRICE_FILANTE
STRIPE_PRICE_LUNE=price_xxx                # = VITE_STRIPE_PRICE_LUNE
STRIPE_PRICE_CONSTELLATION=price_xxx       # = VITE_STRIPE_PRICE_CONSTELLATION
STRIPE_PRICE_GALAXIE=price_xxx             # = VITE_STRIPE_PRICE_GALAXIE

# Meta (WhatsApp Cloud API + Instagram Messaging)
META_APP_SECRET=                            # signature webhook HMAC-SHA256
META_VERIFY_TOKEN=                          # chaîne arbitraire (saisie aussi côté Meta)
META_GRAPH_VERSION=v21.0                    # optionnel (défaut v21.0)
META_GUIDANCE_TEMPLATE_NAME=guidance_quotidienne
META_GUIDANCE_TEMPLATE_LANG=fr
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=                      # System User token longue durée
INSTAGRAM_BUSINESS_ID=
INSTAGRAM_PAGE_ACCESS_TOKEN=                # Page Access Token longue durée

# Web Push (VAPID — côté serveur)
VAPID_PUBLIC_KEY=                           # = VITE_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=                          # SECRET
VAPID_SUBJECT=mailto:contact@zodiakastro.com

# Admin (CSV) — protège meta-test-send.ts
ADMIN_EMAILS=admin@zodiakastro.com

# Auto-injectées par Netlify (ne pas définir manuellement) :
#   URL, DEPLOY_PRIME_URL
